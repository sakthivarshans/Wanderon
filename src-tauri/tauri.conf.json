{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "vite build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "WanderOn",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true,
        "execute": true,
        "sidecar": true,
        "scope": [
          { "name": "wanderon-backend", "sidecar": true, "args": true }
        ]
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://*", "https://*"]
      },
      "path": { "all": true },
      "fs": {
        "all": true,
        "scope": ["$APPDATA/*", "$APPCONFIG/*", "$HOME/.wanderon/*"]
      },
      "notification": { "all": true },
      "window": { "all": true },
      "globalShortcut": { "all": true },
      "os": { "all": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.wanderon.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": ["../backend/**/*"],
      "externalBin": []
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "WanderOn",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "systemTray": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  }
}
